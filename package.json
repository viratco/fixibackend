{
    "name": "fixi-backend",
    "version": "1.0.0",
    "description": "Fixi backend API — TypeScript + Prisma + PostgreSQL",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "db:seed": "ts-node prisma/seed.ts",
        "db:clean": "ts-node prisma/clean-db.ts",
        "generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^5.10.2",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.70.4",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/ioredis": "^4.28.10",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.0",
        "prisma": "^5.10.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
